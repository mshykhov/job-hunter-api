# Database
DB_HOST=localhost
DB_PORT=5440
DB_NAME=jobhunter
DB_USERNAME=jobhunter
DB_PASSWORD=jobhunter
DB_POOL_SIZE=10

# Server
SERVER_PORT=8080

# Auth0
AUTH0_ENABLED=false
AUTH0_ISSUER=https://your-tenant.auth0.com/
AUTH0_AUDIENCE=https://api.jobhunter.example.com

# AI
# AI_MATCHING_CONCURRENCY=10

# AI Encryption (generate with: openssl rand -base64 32)
AI_ENCRYPTION_KEY=

# Logging
LOG_LEVEL_APP=INFO
# LOG_LEVEL_ROOT=INFO
# LOG_LEVEL_WEB=WARN
# LOG_LEVEL_SQL=WARN

# Proxy (Webshare)
# PROXY_ENABLED=false
# WEBSHARE_API_KEY=

# Browser Fingerprints (ScrapeOps)
# SCRAPEOPS_ENABLED=false
# SCRAPEOPS_API_KEY=
